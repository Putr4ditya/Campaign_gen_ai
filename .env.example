# ─────────────────────────────────────────────────────────────
# CampaignAI — Environment Variables Template
# ─────────────────────────────────────────────────────────────
# 1. Salin file ini: cp .env.example .env
# 2. Isi nilai di bawah dengan API key milikmu
# 3. JANGAN pernah commit file .env ke GitHub!
# ─────────────────────────────────────────────────────────────

# Google Gemini API Key
# Daftar gratis di: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Flask Secret Key (bisa diisi sembarang string acak)
FLASK_SECRET_KEY=change_this_to_a_random_secret_string

# Environment (development / production)
FLASK_ENV=development
